FROM node:20-alpine

# Install pnpm
RUN npm install -g pnpm@8.10.5

WORKDIR /app

# Copy package files
COPY package.json pnpm-lock.yaml ./

# Install dependencies
RUN pnpm install

# Copy application
COPY . .

EXPOSE 3011

# Start dev server with hot reload
CMD ["sh", "-c", "pnpm run dev -- -H 0.0.0.0 -p 3011"]
